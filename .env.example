# ──────────────────────────────────────────────────────────────
# QueryMind — Environment Configuration
# Copy this file to .env and adjust values for your setup.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection (host port mapped in docker-compose.yml)
QUERYMIND_DB_URL=postgresql://querymind:querymind@localhost:5434/tpch

# Path to trained PPO model checkpoint
QUERYMIND_MODEL_PATH=checkpoints/querymind_final

# Logging level (DEBUG, INFO, WARNING, ERROR)
QUERYMIND_LOG_LEVEL=INFO

# API server settings
QUERYMIND_HOST=0.0.0.0
QUERYMIND_PORT=8000

# Weights & Biases (optional — set to your API key for experiment tracking)
# WANDB_API_KEY=your_key_here
# WANDB_PROJECT=querymind
